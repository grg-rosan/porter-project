generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum VehicleType {
  BIKE
  SCOOTER
  VAN
  MINI_TRUCK
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum Role {
  CUSTOMER
  RIDER
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum NotificationType {
  // order notifications
  ORDER_PLACED
  ORDER_ASSIGNED
  ORDER_PICKED_UP
  ORDER_DELIVERED
  ORDER_CANCELLED

  // rider notifications
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED

  // admin notifications
  COMPLAINT
  NEW_RIDER_APPLICATION
}

model User {
  userID   String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role

  isBlocked   Boolean   @default(false)
  blockedAt   DateTime?
  blockReason String?   
  createdAt DateTime @default(now())

  riderProfile    RiderProfile?
  customerProfile CustomerProfile?
  notifications   Notification[]
}

model CustomerProfile {
  customerID String @id @default(uuid())
  userID     String @unique

  // contact
  phone        String?
  profileImage String?

  // address
  address   String?
  city      String?
  latitude  Float?
  longitude Float?

  // verification
  isVerified         Boolean            @default(false)
  verificationStatus VerificationStatus @default(UNVERIFIED)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user   User    @relation(fields: [userID], references: [userID])
  orders Order[]
}

model RiderProfile {
  riderID String @id @default(uuid())
  userID  String @unique

  // contact
  phone        String?
  profileImage String?

  // vehicle
  vehicle_type   VehicleType
  vehicle_number String?
  vehicle_image  String? // photo of the vehicle

  // license
  license_number String  @unique
  license_image  String? // photo of license

  // identity verification
  governmentID       String? // national ID / passport number
  governmentID_image String?

  // verification
  isVerified         Boolean            @default(false)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verificationNote   String? // admin rejection reason

  // availability & location
  isAvailable Boolean @default(false)
  latitude    Float?
  longitude   Float?

  // stats
  rating          Float @default(0.0)
  totalDeliveries Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userID], references: [userID])
  orders Order[]
}

model Order {
  ID Int @id @default(autoincrement())

  customerID String
  riderID    String?

  pickup_address String
  drop_address   String
  vehicle_type   VehicleType
  order_status   OrderStatus   @default(PENDING)
  order_weight   Float
  total_amount   Float
  payment_status PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerProfile CustomerProfile @relation(fields: [customerID], references: [customerID])
  riderProfile    RiderProfile?   @relation(fields: [riderID], references: [riderID])

  payment      Payment[]
  notification Notification[]
}

model Payment {
  ID      Int    @id @default(autoincrement())
  orderID Int
  amount  Float
  method  String
  status  String

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderID], references: [ID])
}

model Notification {
  ID Int @id @default(autoincrement())

  userID String
  user   User   @relation(fields: [userID], references: [userID])

  type    NotificationType
  message String
  isRead  Boolean          @default(false)

  orderID   Int?
  order     Order?   @relation(fields: [orderID], references: [ID])
  createdAt DateTime @default(now())
}
