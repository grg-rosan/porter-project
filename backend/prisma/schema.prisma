generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum VehicleType {
  BIKE
  SCOOTER
  VAN
  MINI_TRUCK
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum Role {
  CUSTOMER
  RIDER
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum NotificationType {
  // order notifications
  ORDER_PLACED
  ORDER_ASSIGNED
  ORDER_PICKED_UP
  ORDER_DELIVERED
  ORDER_CANCELLED

  // rider notifications
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED

  // admin notifications
  COMPLAINT
  NEW_RIDER_APPLICATION
}
enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ComplaintType {
  RIDER_BEHAVIOR
  LATE_DELIVERY
  WRONG_ITEM
  PAYMENT_ISSUE
  OTHER
}

enum ComplaintRole {
  CUSTOMER
  RIDER
}

model FareConfig {
  id          Int         @id @default(autoincrement())
  vehicleType VehicleType @unique
  baseFare    Float
  perKm       Float
  perKg       Float
  minFare     Float
  updatedAt   DateTime    @updatedAt
}

model SurgeConfig {
  id          Int      @id @default(autoincrement())
  isActive    Boolean
  multiplier  Float
  reason      String?
  startedAt   DateTime
  endedAt     DateTime? 
}

model User {
  userID   String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role

  // identity verification — applies to BOTH customer and rider
  verificationStatus    VerificationStatus @default(UNVERIFIED)
  verificationNote      String?
  governmentID          String?            @unique
  governmentID_image    String?
  governmentID_publicId String?

  isBlocked   Boolean   @default(false)
  blockedAt   DateTime?
  blockReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  riderProfile    RiderProfile?
  customerProfile CustomerProfile?
  notifications   Notification[]
  complaintsFiled  Complaint[] @relation("ComplaintsFiled")
  complaintsAgainst Complaint[] @relation("ComplaintsAgainst")
}

model CustomerProfile {
  customerID String  @id @default(uuid())
  userID     String  @unique
  phone      String?

  profileImage          String?
  profileImage_publicId String?

  address   String?
  city      String?
  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user   User    @relation(fields: [userID], references: [userID])
  orders Order[] @relation()
}

model RiderProfile {
  riderID String @id @default(uuid())
  userID  String @unique

  phone                 String?
  profileImage          String?
  profileImage_publicId String?

  vehicle_type     VehicleType
  vehicle_number   String?
  vehicle_model    String?
  vehicle_image    String? // photo of the vehicle
  vehicle_publicId String?

  // license
  license_number   String  @unique
  license_image    String? // photo of license
  license_publicId String?

  // identity verification
  governmentID          String? // national ID / passport number
  governmentID_image    String?
  governmentID_publicId String?

  // verification
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verificationNote   String? // admin rejection reason

  // availability & location
  isAvailable Boolean @default(false)
  latitude    Float?
  longitude   Float?

  // stats
  rating          Float @default(0.0)
  totalDeliveries Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userID], references: [userID])
  orders Order[]
}

model Order {
  ID Int @id @default(autoincrement())

  customerID String
  riderID    String?

  pickup_address String
  drop_address   String
  vehicle_type   VehicleType
  order_status   OrderStatus   @default(PENDING)
  weight_kg   Float
  surgeMultiplier Float @default(1.0)
  estimatedFare Float
  finalFare   Float
  payment_status PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerProfile CustomerProfile @relation(fields: [customerID], references: [customerID])
  riderProfile    RiderProfile?   @relation(fields: [riderID], references: [riderID])

  payment      Payment[]
  notification Notification[]
  complaints Complaint[]
}

model Payment {
  ID      Int    @id @default(autoincrement())
  orderID Int
  amount  Float
  method  String
  status  String

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderID], references: [ID])
}

model Notification {
  ID Int @id @default(autoincrement())

  userID String
  user   User   @relation(fields: [userID], references: [userID])

  type    NotificationType
  message String
  isRead  Boolean          @default(false)

  orderID   Int?
  order     Order?   @relation(fields: [orderID], references: [ID])
  createdAt DateTime @default(now())
}

model Complaint {
  ID Int @id @default(autoincrement())

  // who filed it — store userID directly, not profile ID
  filedByUserID String
  filedByRole   ComplaintRole

  orderID Int

  // who it's against — nullable, some complaints are about the platform
  againstUserID String?

  type        ComplaintType
  description String
  status      ComplaintStatus @default(OPEN)
  adminNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  filedBy User  @relation("ComplaintsFiled", fields: [filedByUserID], references: [userID])
  against User? @relation("ComplaintsAgainst", fields: [againstUserID], references: [userID])
  order   Order @relation(fields: [orderID], references: [ID])
}